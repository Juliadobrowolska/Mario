{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "Build Game",
            "command": "C:\\msys64\\ucrt64\\bin\\g++.exe",
            "args": [
                "-g",
                "-std=c++20",
                "${workspaceFolder}\\*.cpp",
                "-I${workspaceFolder}\\Headers",
                "-o",
                "${workspaceFolder}\\game.exe",
                "-lsfml-graphics",
                "-lsfml-window",
                "-lsfml-system"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}